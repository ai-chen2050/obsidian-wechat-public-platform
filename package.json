{
	"name": "wechat-public-cli",
	"version": "1.0.0",
	"description": "CLI for publishing and downloading WeChat Public Platform and Baijiahao content.",
	"main": "main.js",
	"bin": {
		"wechat-public-cli": "dist/wechat-public-cli.js"
	},
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"build:cli": "node esbuild.cli.mjs",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"prepublishOnly": "npm run build:cli"
	},
	"keywords": [
		"obsidian",
		"wechat",
		"baijiahao",
		"cli",
		"openclaw"
	],
	"author": "",
	"license": "MIT",
	"homepage": "https://github.com/ai-chen2050/obsidian-wechat-public-platform",
	"repository": {
		"type": "git",
		"url": "https://github.com/ai-chen2050/obsidian-wechat-public-platform.git"
	},
	"publishConfig": {
		"access": "public"
	},
	"engines": {
		"node": ">=16"
	},
	"files": [
		"dist",
		"skill",
		"README.md",
		"LICENSE"
	],
	"devDependencies": {
		"@types/markdown-it": "^13.0.7",
		"@types/node": "^16.18.76",
		"@typescript-eslint/eslint-plugin": "5.29.0",
		"@typescript-eslint/parser": "5.29.0",
		"builtin-modules": "3.3.0",
		"esbuild": "0.17.3",
		"obsidian": "latest",
		"tslib": "2.4.0",
		"typescript": "4.7.4",
		"@types/node-fetch": "2.6.12"
	},
	"dependencies": {
		"@types/lodash.pickby": "^4.6.9",
		"@types/mime": "^3.0.4",
		"@types/mime-types": "^2.1.4",
		"@types/set-cookie-parser": "^2.4.2",
		"form-data": "^4.0.0",
		"https-proxy-agent": "^7.0.2",
		"jimp": "^0.22.10",
		"juice": "^10.0.0",
		"lodash.pickby": "^4.6.0",
		"marked": "^12.0.1",
		"highlight.js": "^11.9.0",
		"marked-highlight": "^2.1.3",
		"mime": "^4.0.1",
		"mime-types": "^2.1.35",
		"node-html-markdown": "^1.3.0",
		"node-fetch": "2.7.0",
		"set-cookie-parser": "^2.5.0",
		"svelte": "^4.2.8",
		"weixin-js-sdk": "^1.6.5",
		"ytdl-core": "^4.11.5"
	}
}